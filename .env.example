# Application Settings
APP_NAME=పద్యార్చన - Padyarchana
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite+aiosqlite:///./padyarchana.db

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Search
SEARCH_RESULTS_LIMIT=100

# Paths
STATIC_DIR=static
TEMPLATES_DIR=app/templates
DATA_DIR=data

# Audio Settings
AUDIO_DIR=static/audio/poems
MAX_AUDIO_FILE_SIZE=52428800
ALLOWED_AUDIO_FORMATS=mp3,wav

# Auth — REQUIRED in production. Defaults below are for local development only.
# The app will REFUSE to start if ENVIRONMENT != "development" and any of these
# are still set to their defaults (see app/config.py:_check_prod_defaults).
SESSION_SECRET=dev-only-change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
VIEWER_USERNAME=viewer
VIEWER_PASSWORD=viewer
