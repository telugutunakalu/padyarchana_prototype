      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 7,
      "padyam_number": 7
    },
    {
      "lines_telugu": [
        "వైష్ణవమాయాగుణ వ",
        "ర్థుష్ణుత జాటఁగ నుమాపతిన్ఘన మాయా",
        "నిష్ణాతు న్మోహినివై",
        "దృష్ణత బాపవె విలాస ధుర్యతఁ కృష్ణా!"
