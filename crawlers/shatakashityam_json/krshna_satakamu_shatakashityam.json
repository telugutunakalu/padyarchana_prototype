        "సాదృశహీనమహామహి",
        "మా దారియగుచు వెలుఁగు నుమాపతి కృష్ణా!"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 6,
      "padyam_number": 6
    },
    {
      "lines_telugu": [
        "సతి సుతహిత జనజలచర",
