  "note": "Crawled from the శతకసాహిత్యం blog (shatakashityam.blogspot.com).",
  "poems": [
    {
      "lines_telugu": [
        "శ్రీకర! మునిమానసమో",
        "దాకర! జితనీలనీరదశ్యామా! ల",
        "క్ష్మీకాంతా హృద్రమ్య",
        "శ్రీకైరవకైరవాప్త! జేజేకృష్ణా!"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 1,
      "padyam_number": 1
    },
    {
      "lines_telugu": [
        "భువి జక్రవరపు వంశో",
        "ద్భవు శాస్త్ర నిగమ పురాణ పారంగతునిన్",
        "కవివరగురువేంకటరా",
        "య, విబుధవర్యు గొలుతు ననయంబును కృష్ణా!"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 2,
      "padyam_number": 2
    },
    {
      "lines_telugu": [
        "వాణిని శాస్త్రనిగమచయ",
        "పాణినిఁ బద్మజురమణిని ప్రాకట సుగుణ",
        "శ్రేణిని పన్నగసన్నిభ",
        "వేణిని మృదుపలుకు లొసఁగ వేడెదు కృష్ణా!"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 3,
      "padyam_number": 3
    },
    {
      "lines_telugu": [
        "అసదృశ కవితా సృష్టులు",
        "పస నొనరించియు వెలుంగు భాసురకవిలో",
        "క సుధాకరులకు మ్రొక్కి, స",
        "రసత శతకమును రచింతు రాధాకృష్ణా!"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 4,
      "padyam_number": 4
    },
    {
      "lines_telugu": [
        "అదీది యనగను కుదరని",
        "మదినొక నలత జలఁగి యరమరకలు వెట్టన్",
        "బెదరియు నుపశమనమునకు",
        "మది యలరఁగ నిది నుడివెద మాధవకృష్ణా!"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 5,
      "padyam_number": 5
    },
    {
      "lines_telugu": [
        "పాదోద్భవ గంగాఝరి",
