  "poems": [
    {
      "lines_telugu": [
        "శ్రీజనకాత్మజా విమల",
        "చిత్తసరోజనివాస! *ద్యోరమా",
        "రాజకిరీటహీరమణి",
        "రాజితపాద! పరాత్పరా! భర",
        "ద్వాజమునీంద్రపూజిత! వి",
        "దారితశాత్రవ! సన్నమోఘ వి",
        "ర్వ్యాజ కృపావలోకనల",
        "వారకజూడుము భక్తజీవనా!",
        "(ద్యోరమారాజ :ఇంద్ర)"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 1,
      "padyam_number": 1
    },
    {
      "lines_telugu": [
        "సామజపాలకా! జలజ",
