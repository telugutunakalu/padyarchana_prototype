      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 2,
      "padyam_number": 2
    },
    {
      "lines_telugu": [
        "ఏమి శారదాంబ! ఎలమితో మానాల్క",
