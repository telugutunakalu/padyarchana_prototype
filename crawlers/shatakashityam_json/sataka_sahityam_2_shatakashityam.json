  "poems": [
    {
      "lines_telugu": [
        "శ్రీపదంబ నిన్ను చేర్చి మొట్టమొదట",
        "చేతికొద్దివ్రాయజూతు మహహ",
        "తప్పులున్న యెడల తప్పునీదేసుమా",
        "విశ్వదాభిరామ విసనకర్ర!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 1,
      "padyam_number": 1
    },
    {
      "lines_telugu": [
        "ప్రధమ భాగము",
