  "poems": [
    {
      "lines_telugu": [
        "శ్రీపార్థసారథీ! నేఁ",
        "బాపాత్ముఁడ నీదు పాలఁ బడినాడ ననుం",
        "గాపాడు మనుచు నాంతర",
        "కోపాదు లడంచి వేఁడు గువ్వల చెన్నా!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 1,
      "padyam_number": 1
    },
    {
      "lines_telugu": [
        "నర జన్మ మెత్తి నందున",
        "సరసిజనాభు నెదలోన స్మరియించుచుఁ ద",
        "చ్చరణములు మఱవ కుండిన",
        "గురుఫల మగు జన్మమునకు గువ్వల చెన్నా!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 2,
      "padyam_number": 2
    },
    {
      "lines_telugu": [
        "ఎంతటి విద్యలఁనేర్చిన",
