        "నీరెంత పోసి పెంచినఁ",
        "గూరగునా వేలవేము గువ్వల చెన్న!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 4,
      "padyam_number": 4
    },
    {
