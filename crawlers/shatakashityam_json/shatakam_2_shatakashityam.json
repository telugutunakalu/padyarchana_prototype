        "గొంతుకఁ దడుపుకొనుకొఱకె గువ్వల చెన్నా!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 3,
      "padyam_number": 3
    },
    {
