  "poems": [
    {
      "lines_telugu": [
        "కరిణకమునకుఁ గరణికము",
        "కరతత్తికిఁ దత్సమంబు కరదృతి యయ్యెన్",
        "కరిసెకుఁ గర్షంబందురు",
        "కరసానకుఁ తత్సమంబు కరశాణయగున్"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 1,
      "padyam_number": 1
    },
    {
