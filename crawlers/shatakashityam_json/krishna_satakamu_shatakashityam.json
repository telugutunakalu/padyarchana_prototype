        "విదితంబుగ బహురూపుల",
        "బెదరక భోగింతువౌర వేడుక కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 23,
      "padyam_number": 23
    },
    {
      "lines_telugu": [
        "అంగన పనుపున ధోవతి",
