        "సంగడి విప్రునకిడితివి",
        "రంగుగ సంపదలు లోకరక్షక కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 24,
      "padyam_number": 24
    },
    {
      "lines_telugu": [
