        "ఆవనజాక్షికి నిడితివి",
        "శ్రీవర యక్షయమటంచుఁ జీరెలు కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 25,
      "padyam_number": 25
    },
    {
