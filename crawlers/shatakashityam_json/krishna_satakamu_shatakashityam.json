        "సంసారి రీతినుంటివి",
        "సంసాదితవైరి సత్ప్రశంసిత కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 22,
      "padyam_number": 22
    },
    {
      "lines_telugu": [
