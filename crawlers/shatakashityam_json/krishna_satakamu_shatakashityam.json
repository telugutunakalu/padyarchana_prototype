{
  "shatakam_title_telugu": "కృష్ణ శతకము",
  "author_telugu": "నృసింహకవి",
  "year": "unknown",
  "literary_form_telugu": "శతకము",
  "source_url": "https://shatakashityam.blogspot.com/2013/12/blog-post.html",
  "note": "Crawled from the శతకసాహిత్యం blog (shatakashityam.blogspot.com).",
  "poems": [
    {
      "lines_telugu": [
        "శ్రీరుక్మిణీశ కేశవ",
        "నారదసంగీతలోల నగధరశౌరీ",
        "ద్వారక నిలయ జనార్ధన",
        "కారుణ్యముతోడ మమ్ముఁ గావుము కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 1,
      "padyam_number": 1
    },
    {
      "lines_telugu": [
        "నీవే తల్లియు తండ్రివి",
        "నీవే నాతోడునీడ నీవే సఖుఁడౌ",
        "నీవేగురుడవు దైవము",
        "నీవే నాపతియు గతియు నిజముగ కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 2,
      "padyam_number": 2
    },
    {
      "lines_telugu": [
        "నారాయణ పరమేశ్వర",
        "ధారాధర నీలదేహ దానవవైరీ",
        "క్షీరాబ్ధిశయన యదుకుల",
        "వీరా ననుగావు కరుణ వెలయఁగ కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 3,
      "padyam_number": 3
    },
    {
      "lines_telugu": [
        "హరియను రెండక్షరములు",
        "హరియించును పాతకంబు లంబుజనాభా",
        "హరి నీనామమహత్త్వము",
        "హరి హరి పొగడంగ వశమె శ్రీకృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 4,
      "padyam_number": 4
    },
    {
      "lines_telugu": [
        "క్రూరాత్ముఁ డజమీళుఁడు",
        "నారాయణయనుచు నాత్మనందను బిలువన్",
        "ఏరీతి నేలుకొంటివి",
        "ఏరీ నీసాటివేల్పు లెందును కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 5,
      "padyam_number": 5
    },
    {
      "lines_telugu": [
        "చిలుకనొకరమణి ముద్దులు",
        "చిలుకను శ్రీరామయనుచు శ్రీపతిపేరన్",
        "బిలిచిన మోక్షము లియ్యఁగ",
        "అలరఁగ మిముఁ దలచుజనులకరుదా కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 6,
      "padyam_number": 6
    },
    {
      "lines_telugu": [
        "అక్రూరవరద మాధవ",
        "చక్రాయుధ ఖడ్గపాణి శార్జ్గిముకుందా",
        "చక్రాదిదివిజసన్నుత",
        "శుక్రార్చిత నన్ను కరుణజూడుము కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 7,
      "padyam_number": 7
    },
    {
      "lines_telugu": [
        "నందుని ముద్దులపట్టిని",
        "మందరగిరిధరుని హరిని మాధవ విష్ణున్",
        "సుందరరూపుని మునిగణ",
        "వందితు మిముఁ దలతు భక్తవత్సల హరీ కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 8,
      "padyam_number": 8
    },
    {
      "lines_telugu": [
        "ఓకారుణ్యపయోనిధి",
        "నాకాధారంబ వగుచు నయముగఁ బ్రోవన్",
        "నాకేల యితరచింతలు",
        "నాకాధిపవినుత లోకనాయక కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 9,
      "padyam_number": 9
    },
    {
      "lines_telugu": [
        "వేదంబులు గన నేరని",
        "యాది పరబ్రహ్మమూర్తి యనఘ మురారీ",
        "నాదిక్కుఁ జూచి గావుము",
        "నీదిక్కే నమ్మినాను నిజముగఁ కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 10,
      "padyam_number": 10
    },
    {
      "lines_telugu": [
        "పదునాలుగు భువనంబులు",
        "కుదురుగ నీకుక్షి నిల్పుకొని నేర్పరివై",
        "విదితంబుగ బా దేవకి",
        "యుదరములో నెట్టులొదిగియుంటివి కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 11,
      "padyam_number": 11
    },
    {
      "lines_telugu": [
        "అష్టమి రోహిణిప్రొద్దున",
        "నష్టమగర్భమునఁ బుట్టి యాదేవకికిం",
        "దుష్టుని గంసు వధింపవె",
        "సృష్టిప్రతిపాదనంచుసేయగ కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 12,
      "padyam_number": 12
    },
    {
      "lines_telugu": [
        "అల్లజగన్నాధుకు రే",
        "పల్లియు క్రీడార్థమయ్యెఁ బరమాత్మునకున్",
        "గొల్లసతి యాయశోదయుఁ",
        "దల్లియునై చన్ను గుడిపెఁ దనరగఁ కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 13,
      "padyam_number": 13
    },
    {
      "lines_telugu": [
        "అందెలు గజ్జెలు మ్రోయగఁ",
        "జిందులు ద్రొక్కుచును వేడ్క చెలువారంగా",
        "నందుని సతి యాగోపిక",
        "ముందర నాడుదువు మిగుల మురియుచుఁ కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 14,
      "padyam_number": 14
    },
    {
      "lines_telugu": [
        "హరి చందనంబు మేనను",
        "గర మొప్పెడు హస్తములను గంకణరవముల్",
        "ఉరమున రత్నము మెఱయఁగఁ",
        "బరగితి వౌనీవు బాలప్రాయము కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 15,
      "padyam_number": 15
    },
    {
      "lines_telugu": [
        "పాణీతలంబున వెన్నయు",
        "వేణీమూలంబునందు వెలయఁగ బింఛం",
        "బాణీముత్యము ముక్కున",
        "జాణఁడవై దాల్తు శేషశాయివి కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 16,
      "padyam_number": 16
    },
    {
      "lines_telugu": [
        "మడుగుకుఁ జని కాళింగుని",
        "పడగలపై భరతశాస్త్రపద్ధతివెలయం",
        "గడు వేడుకతో నాడెడు",
        "నడుగులు నేమదిని దాల్తు నచ్యుతకృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 17,
      "padyam_number": 17
    },
    {
      "lines_telugu": [
        "బృందావనౌన బ్రహ్మా",
        "నందార్భకమూర్తి వేణునాదము నీవుం",
        "మందారమూలమున గో",
        "విందా పూరింతువౌర వేడుక కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 18,
      "padyam_number": 18
    },
    {
      "lines_telugu": [
        "వారిజనేత్రలు యమునా",
        "వారిని జలకంబులాడవచ్చిన నీవుం",
        "జీరెలుమ్రుచ్చిలి యిస్తివి",
        "నేరుపురా యిదియునీకు నీతియె కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 19,
      "padyam_number": 19
    },
    {
      "lines_telugu": [
        "దేవేంద్రుఁ డలుకతోడను",
        "వావిరిగా రాళ్ళవాన వడిగురియింపన్",
        "గోవర్ధనగిరియెత్తితి",
        "గోవుల గోపకులఁ గాచుకొఱకై కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 20,
      "padyam_number": 20
    },
    {
      "lines_telugu": [
        "అండజవాహన విను బ్ర",
        "హ్మాండంబుల బంతులట్లు యాడెడునీవున్",
        "గొండలనెత్తితి వందురు",
        "కొండికపనిగాక దొడ్డకొండా కృష్ణా"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null,
      "id": 21,
      "padyam_number": 21
