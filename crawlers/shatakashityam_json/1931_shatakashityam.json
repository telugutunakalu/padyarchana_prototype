{
  "shatakam_title_telugu": "అభినవ సుమతి శతకము",
  "author_telugu": "దుర్భా సుబ్రహ్మణ్యశర్మ",
  "year": "unknown",
  "literary_form_telugu": "శతకము",
  "source_url": "https://shatakashityam.blogspot.com/2019/06/1931.html",
  "note": "Crawled from the శతకసాహిత్యం blog (shatakashityam.blogspot.com).",
  "poems": [
    {
      "lines_telugu": [
        "శ్రీదంబులు, భవపాశ",
        "చ్చేదంబులు, సకలభక్త చిత్తాంబురుహా",
        "మోదంబులు, పరమేశ్వరు",
        "పాదంబులు కొలుచువాడు ప్రాజ్ఞుడు; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 1,
      "padyam_number": 1
    },
    {
      "lines_telugu": [
        "ఇలక్రుంగకుండ, వారా",
        "సులు మేరలు మీఱకుండ, సూర్యాదులు దా",
        "రులు సప్పకుండ, నెవ్వఁడు",
        "తెలివిన్ నియమించె నతఁడె దేవుఁడు; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 2,
      "padyam_number": 2
    },
    {
      "lines_telugu": [
        "తలపోసి మనుజు లీశ్వరు",
        "నలఘు మహత్త్వంబు దెలియ నాసపడుట, యా",
        "జలరాశిలోఁతు గనుఁగొనఁ",
        "జలిచీమల పైనమైన చందము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 3,
      "padyam_number": 3
    },
    {
      "lines_telugu": [
        "ఒరులెవరు చూడలేదని",
        "దురితంబులు సలుపఁబోకు దుష్టాత్ముఁడవై,",
        "నిరతము వేగన్నులతోఁ",
        "బరమేశుఁడు చూచుచున్న వాఁడుర; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 4,
      "padyam_number": 4
    },
    {
      "lines_telugu": [
        "ప్రత్యక్షదైవంబులు",
        "సత్యముగా నీకు నీదు జననీజనకుల్;",
        "ప్రత్యహము వారిఁ గొలువుము",
        "నిత్యైశ్వర్యంబు నీకు నెలకొను; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 5,
      "padyam_number": 5
    },
    {
      "lines_telugu": [
        "జనయిత్రికంటె దైవము",
        "జనకునికంటెను గురుండు, జనహితరతికం",
        "టెను మేలు, జనవిరోధం",
        "బునకంటెను గీడు లేదు భువిలో; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 6,
      "padyam_number": 6
    },
    {
      "lines_telugu": [
        "యెన్నియిడుములకు నోరిచి",
        "నిన్నుంగని పెంచినారొ నీ తలిదండ్రుల్!",
        "మి న్నొఱిగి మీఁదఁ బడఁగా",
        "నున్నను, బిత్రాజ్ఞ మీఱకుండుము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 7,
      "padyam_number": 7
    },
    {
      "lines_telugu": [
        "భౌతికదేహంబునకున్",
        "మాతాపితలట్ల జ్ఞానమయతనువునకున్",
        "హేతువు గావున నొజ్జలఁ",
        "జేతమునన్ నిలిపి భజన సేయుము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 8,
      "padyam_number": 8
    },
    {
      "lines_telugu": [
        "గురుని యవగుణము లెన్నకు,",
        "గురునింద యొనర్చువారిఁ గూడకు, మఱి యా",
        "గురువేది చెప్పెనయ్యది",
        "యరసి యనుష్ఠించి శ్రేయమందుము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 9,
      "padyam_number": 9
    },
    {
      "lines_telugu": [
        "జననియును జన్మభూమియు",
        "జనకుండు జనార్ధనుండు జాహ్నవియు ననన్",
        "జను నీ యైదు ' జ ' కారము",
        "లనయము సేవ్యములు సజ్జనాళికి; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 10,
      "padyam_number": 10
    },
    {
      "lines_telugu": [
        "మనదేశభాష యనియును",
        "మనపుట్టినదేశ మనియు మనదేశంపున్",
        "జనులనియుఁ బ్రీతిఁ బొరయని",
        "మనుజుఁడు జీవన్మృతుండు మహిలో; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 11,
      "padyam_number": 11
    },
    {
      "lines_telugu": [
        "హరుఁ డౌదల నిడికొన్నను",
        "హరిణాంకుఁడు కృశతవీఁడ డది యుక్తమె రా",
        "దొరయెంత సౌమ్యుఁడైనను",
        "పరాశ్రయము దుఃఖకరము ప్రాణికి; కుమతీ"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 12,
      "padyam_number": 12
    },
    {
      "lines_telugu": [
        "పరవేదన మొకయింతయు",
        "నెఱుఁగరు శ్రీమంతు లల ఫణీశుని శిరముల్",
        "ధరక్రింద నులియు చుండఁగ",
        "హరి సుఖముగ నిద్రపోవు నంబుధి; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 13,
      "padyam_number": 13
    },
    {
      "lines_telugu": [
        "సేవావృత్తి శ్వవృత్తిగ",
        "నేవాఁడు వచించె నాతఁ డెఱుగఁడు; శుని స్వే",
        "చ్చావృత్తిఁ దిరుగు, నట్టిది",
        "సేవకునకు నెన్నఁడైన జెల్లునె? సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 14,
      "padyam_number": 14
    },
    {
      "lines_telugu": [
        "సింగమున కెవఁడొసంగెను",
        "రంగుగ మృగరాజపద మరణ్యమున, ను",
        "త్తుంగబలశౌర్యశాలికి",
        "వెంగలుల సహాయమేల వేఁడఁగ; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 15,
      "padyam_number": 15
    },
    {
      "lines_telugu": [
        "కాలం ద్రొక్కిన యంతన",
        "తూలక సిగనంట నెగయు ధూళియు మేలే,",
        "హేళనపడి పగతురపై",
        "నాలమునకుఁ బోని యాపద కంటెను; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 16,
      "padyam_number": 16
    },
    {
      "lines_telugu": [
        "ప్రాణంబు లొడ్డియైనన్",
        "మానము కాపాడుకొనుము మానము తొలఁగం",
        "గా నుండినను, స్వధర్మము",
        "మానకు మిదె ధీరజనుల మార్గము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 17,
      "padyam_number": 17
    },
    {
      "lines_telugu": [
        "వెఱవకుము మృత్య్వునకున్",
        "వెఱవకు బాధలకు, ధరణి విభుశిక్షలకున్,",
        "వెఱవకుము లోకనిందకు,",
        "వెఱవుము తప్పక యధర్మవృత్తికి, సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 18,
      "padyam_number": 18
    },
    {
      "lines_telugu": [
        "న్యాయమునఁ బోవువానికిఁ",
        "బాయక మృగపక్షులైన బాసట యగు, న",
        "న్యాయపరుఁడైనవానిన్",
        "బాయున్ దోఁబుట్టువైన వసుమతి; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 19,
      "padyam_number": 19
    },
    {
      "lines_telugu": [
        "ఎది యెదిరి నీకొనర్చిన",
        "నెద యుమ్మలికమ్మునొందు నెదిరికి నీ వ",
        "య్యది సేయకుండు; మిదియే",
        "సదమల ధర్మోపదేశసారము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 20,
      "padyam_number": 20
    },
    {
      "lines_telugu": [
        "కీర్తికయి ప్రాఁకులాడకు,",
        "వర్తింపుము ధర్మ మెఱిఁగి వారకదానన్",
        "గీర్తియయినఁ గా కున్నను",
        "బూర్తిగఁ బుణ్యంబునీకుఁ బొసఁగును; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 21,
      "padyam_number": 21
    },
    {
      "lines_telugu": [
        "ధర్మమున నిలచి, దానన్",
        "శర్మము శాంతియును గనుటె స్వర్గము; మఱి దు",
        "షర్మంబు చేసి మనమున",
        "నిర్మథనము నొందునదియ నిరయము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 22,
      "padyam_number": 22
    },
    {
      "lines_telugu": [
        "కనకంబు గాదు తలఁపగఁ",
        "గనకాంగియుఁ గాదు, కాదు కాదంబరియున్;",
        "మనుజులకుఁ గైపు కొలిపెడి",
        "పెనురోగము మౌఢ్య మొకఁడె పృథ్విని; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 23,
      "padyam_number": 23
    },
    {
      "lines_telugu": [
        "మృగమునకు నేల ముత్యము",
        "లగణిత మణిదర్పణమ్ము లంధున కేలా?",
        "తగఁ జెవిటి కేల సొరములు,",
        "నిగమార్గము లేల మూఢునికి నిల? సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 24,
      "padyam_number": 24
    },
    {
      "lines_telugu": [
        "జ్ఞానంబుకతనఁ గాదే",
        "మనవుఁ డఖిలార్థసిద్ధిమంతుడగుటల్;",
        "జ్ఞానము విద్యాధీనము",
        "కానన్ గష్టించి విద్య గఱవుము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 25,
      "padyam_number": 25
    },
    {
      "lines_telugu": [
        "ఏనుంగులు సింగంబులు",
        "వానరములు బెలుఁగుబంట్లు వ్యాఘ్రములు నరా",
        "ధీనంబు లగుట, యాతని",
        "ధీనీతి మహత్త్వమంచుఁ దెలియుము; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 26,
      "padyam_number": 26
    },
    {
      "lines_telugu": [
        "స్నానమున మేనిముఱికియు,",
        "జ్ఞానమున మనోమలంబు, శబ్దాగమ వి",
        "జ్ఞానమున నుడిదొసంగులు,",
        "పూని తొలగించుకొనుము పూర్ణత; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 27,
      "padyam_number": 27
    },
    {
      "lines_telugu": [
        "ఎంతెంతచదువు చదివెద",
        "వంతంతకొఱంత యునికి యది విశదమగున్;",
        "ఎంతెంత యది యపూర్ణమొ",
        "అంతంత వృథాభిమాన మడరును; సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 28,
      "padyam_number": 28
    },
    {
      "lines_telugu": [
        "వేసమున కేమి? చాకలి",
        "నాసించిన, వలువ లెట్టివైన లభించున్!",
        "భాసురమగు విద్య, చిరా",
        "భ్యాసంబునఁ గాక యెరవు కబ్బునె? సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 29,
      "padyam_number": 29
    },
    {
      "lines_telugu": [
        "విననేర్చు బధిరుఁ, డంధుఁడు",
        "కన నేర్చున్, నడువ నేర్చు ఖంజుఁడు బళిరా!",
        "అనవరత పరిశ్రమమున",
        "నెనయంగారాని సిద్ధి యెయ్యది? సుమతీ!"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 30,
      "padyam_number": 30
    },
    {
      "lines_telugu": [
        "నీకన్న నధికులం గని",
