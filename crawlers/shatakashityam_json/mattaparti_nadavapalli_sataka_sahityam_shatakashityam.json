        "జ్ఞానబోధయనెడు శతకంబు దీనిని",
        "వినుముజ్ఞానబోధ గనుముమనస"
      ],
      "Chandassu": "unknown",
      "bhavam": null,
      "prathipadartham": null,
      "id": 2,
      "padyam_number": 2
    },
    {
