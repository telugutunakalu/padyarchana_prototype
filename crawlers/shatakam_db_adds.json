[{"source": "బెజవాడ కనకదుర్గాంబ శతకము", "poet_id": 9, "lines": ["తెంబలగా మేకల గొ", "ర్లంబొరిగొని భక్తగణాము రక్షించిన నీ", "సంబర మెంచెద శరజ", "న్మాంబా! బెజవాడ కాళికాంబ! మదాంబా!"], "Chandassu": "కందము", "title_id": 30}, {"source": "భద్రాద్రిసీతారామ శతకము", "poet_id": 11, "lines": ["కమలజు నిగమములన్", "జేకొని సంద్రంబుజొచ్చు చెడుసోమకుమ", "త్స్యాకారమ్మున గూల్చితి", "శ్రీకర భద్రాద్రిధామ సీతారామా!"], "Chandassu": "ఆటవెలది", "title_id": 42}, {"source": "భద్రాద్రిసీతారామ శతకము", "poet_id": 11, "lines": ["కమలజువరమున సుర", "భీకరుడై రావణూండు వేధింపగ నీ", "కాకుత్స్థుడవై గూల్చితి", "శ్రీకర భద్రాద్రిధామ సీతారామా!"], "Chandassu": "ఆటవెలది", "title_id": 48}, {"source": "భద్రాద్రిసీతారామ శతకము", "poet_id": 11, "lines": ["కుచేలుండు పిడికెం", "డేకద యటుకులనొసంగె యేమన నతడ", "స్తోకవిభవంబులందడె", "శ్రీకర భద్రాద్రిధామ సీతారామా!"], "Chandassu": "ఆటవెలది", "title_id": 74}, {"source": "భద్రాద్రిసీతారామ శతకము", "poet_id": 11, "lines": ["కంచర్లాన్వయునిన్", "బాకీకై తురకరాజు బాధలపెట్టం", "బాకీలెల్లను దీర్చితి", "శ్రీకర భద్రాద్రిధామ సీతారామా!"], "Chandassu": "ఆటవెలది", "title_id": 84}, {"source": "భక్తజీవన శతకము", "poet_id": 12, "lines": ["తనయ నొసంగ బంగారపుఁ", "దట్టను నబ్ధివరేణ్యుడెవ్వితా", "వినయము తోడుతన్ గడిగె,", "వేమరు జానకిసేవ జేయు వే", "నిని, ఫణిరాట్ఫణాగ్రముల", "నేర్పున నృత్య్ము సల్పెనేవి, వా", "నిని భవదీయ పాదముల", "నెమ్మి భజింతును భక్తజీవనా!"], "Chandassu": "unknown", "title_id": 23}, {"source": "చన్నకేశవ శతకము", "poet_id": 18, "lines": ["తపముసేయఁగఁ బర్వతాగ్రభాగమువీడి, యూషరక్షేత్రమందుండురీతి", "యేలారజఃపురితేక్షు సారమువీడి, యతితిక్తరసముఁ దాగతుకురీతి", "ఘనరత్నఖచిత కంకణజాలమునువీడి, వన్నెగాజులు దాను గొన్నరీతి", "షడ్రసోపేతమౌ శాల్యోదనమువీడి, జొన్నసంకటిఁగోరి తిన్నరీతి", "గాదె నిను వీడి యజ్ఞానవాదులౌచు", "నరులు దిరుగుట దేవతాంతరమునందు", "మానసములుంచి ముక్తికై దీనబంధు", "సురుచిరవిలాస లశునాఖ్యపురనివాస", "చన్నకేశవదేవ విశాలభావ!"], "Chandassu": "సీసము", "title_id": 90}, {"source": "చన్నకేశవ శతకము", "poet_id": 18, "lines": ["శేషిశబ్ధము నీయందుఁజెంది సుస్థి", "రంబుగాదని యనవసరంబునందు", "నింతచేసితి కాఁబోలు నెంత యుక్తి", "పరుఁడవోగాని నిన్నెట్లు ప్రస్తుతింతు", "సురుచిరవిలాస లశునాఖ్యపురనివాస", "చన్నకేశవదేవ విశాలభావ!"], "Chandassu": "సీసము", "title_id": 95}, {"source": "చన్నకేశవ శతకము", "poet_id": 18, "lines": ["ప్రారబ్ధవశముచేఁ బైఁబడ్డ కష్టముం, బాపి రక్షింప నీభారమంటి", "జన్మలో నొకపరి శరణన్న వారల, కభయప్రదుండ వీవనుచు వింటి", "నే నొనర్చిన పాప నివహము న్సైరించి, త్వభక్తి నిమ్మని తలఁచుచుంటి", "నాయదృష్టంబుచే నఖిల దైవత చక్ర, వర్తివౌ నీయందె వాంఛఁగొంటి", "చిత్తశుద్ధికి భంగంబుఁ జేయకంటి", "నమ్మియుంటిని నిన్మదిం దమ్మికంటి", "సురుచిరవిలాస లశునాఖ్యపురనివాస", "చన్నకేశవదేవ విశాలభావ!"], "Chandassu": "సీసము", "title_id": 105}, {"source": "ద్వారకాపతి శతకము", "poet_id": 24, "lines": ["పేదకుఁ బొట్టనిండె, రిపువేదన లెల్లడ నారియుండె ని", "మ్మేదినిఁబంటపండెఁగడు మేలగుధర్మము హెచ్చుచుండె నిం", "డాదరమున్ గ్రహించెడు జనార్ధనుఁడీవయి పుట్టియుండ న", "న్నీదరిఁ జేర్చికావుము గణింతును నే నిను ద్వారకాపతీ"], "Chandassu": "ఉత్పలమాల", "title_id": 50}, {"source": "ద్వారకాపతి శతకము", "poet_id": 24, "lines": ["నెలకుఁ ద్రివృష్టి నింపి ధరణిన్ వహియింపఁగ సస్యవృద్ధిగో", "వులు పృథివీసురుల్ సుఖముఁబొంద నిలాధిప వైరహీనమై", "కలిమియుఁ జెల్మియుండ జనకాండముఁ దక్కిన సర్వజీవులు", "జ్వలనముదమ్మునందఁగృప బాలనఁజేయవె ద్వారకాపతీ"], "Chandassu": "చంపకమాల", "title_id": 107}, {"source": "ఇందిరా శతకము", "poet_id": 27, "lines": ["చ్. వరఘనసార కుంకుమసువాసితగంధ మలంది మేన క", "స్తురితిలకంబు ఫాలమున శోభిలగూర్తు శుభాంజనం బిదే", "తరళదృగంచలంబులను దాల్పవె, రోచనపత్రకంబులన్", "సురుచిరగండభాగముల సొంపొనగూర్చెదనమ్మ యిందిరా"], "Chandassu": "unknown", "title_id": 89}, {"source": "ఇందిరా శతకము", "poet_id": 27, "lines": ["ఈమహితేందిరాశతక మెవ్వడు భక్తి పఠించు సంతతం", "బామనుజాగ్రహణ్యుగృహమం దెపుడున్వసియించి సత్కృపన్", "కామితదివ్యవైభవ సుఖస్థితి నైహికపారలౌకిక", "క్షేమములాదృతిన్ గలుగజేయుచు నిందిరవాని బ్రోచెడున్"], "Chandassu": "ఉత్పలమాల", "title_id": 107}, {"source": "ఇందిరా శతకము", "poet_id": 27, "lines": ["స్వస్తి సమస్త ప్రజకు సంతతము న్గణుతింప న్యాయమా", "ర్గస్తులరై నృపాలురు ధర్మస్థలి బ్రోతురుగాత బ్రీతితో", "నిస్తులమౌ శుభం బగుత నిత్యము గోగణవిప్రజాతికిన్", "విస్తరసౌఖ్యసంపదల విశ్వ