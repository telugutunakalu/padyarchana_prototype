 "poems": [
  {
   "id": 1,
   "padyam_number": 1,
   "lines_telugu": [
    "శ్రీనివాసుడితడు శిశువురూపమునొంది",
    "సేవచేసుకొనగ చేరిరాగ",
    "పాలుకలిపిపెడితిపద్యమొక్కొక్కటి!",
    "శిశువు చేష్టలేమి చిత్రమౌర!"
   ],
   "Chandassu": "unknown",
   "bhavam": null,
   "prathipadartham": null
  },
  {
