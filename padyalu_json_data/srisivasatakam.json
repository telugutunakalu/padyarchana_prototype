{
  "shatakam_title_telugu": "శ్రీ శివ శతకము",
  "author_telugu": "హ.వేం.స.నా.మూర్తి",
  "year": "క్రీ.శ 20వ – 21వ శతాబ్దం",
  "literary_form_telugu": "శతకము",
  "source_url": null,
  "note": "శతరుద్రీయ శివశతకము (కందములు, ౧౧౨ పద్యాలు); OCR నుండి సేకరించబడింది.",
  "poems": [
    {
      "id": 1,
      "lines_telugu": [
        "శ్రీ విఘ్నేశుని దలచెద",
        "గోవిందుని బ్రహ్మనట్లె గురుతర భక్తిన్",
        "సేవించెద గౌరిని రమ",
        "నావాణిని దలచువాడ నదనెంచి శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 1,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 2,
      "lines_telugu": [
        "కులదేవుని వేంకటపతి",
        "నలఘు జ్ఞానాఢ్యుడైన యాగురువర్యున్",
        "దలచెద నారాయణఘను",
        "పలికించగ సాధుపద్య పంక్తులను శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 2,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 3,
      "lines_telugu": [
        "పలుకుట నేర్పిన వారగు",
        "తలిదండ్రుల సన్నుతించి తదనంతర మీ",
        "తెలుగును భరతావనిలో",
        "వెలిగించిన పూర్వకవుల వినుతింతు శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 3,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 4,
      "lines_telugu": [
        "శత మష్టోత్తరసంఖ్యా",
        "యుతముగ పద్యములు చెప్ప నుద్యుక్తుడనై",
        "క్షితి నిలిచితి నీ యెదుటను",
        "నతులను గొని పలుకు శక్తి నాకిమ్ము శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 4,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 5,
      "lines_telugu": [
        "ఛందంబులు యత్యాదులు",
        "నందముగా బలుకురీతు లరయని వాడన్",
        "మందుడ నా యీ కోరిక",
        "వందనమిదె తీర్చుమయ్య వామాంగ శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 5,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 6,
      "lines_telugu": [
        "హరివంశ సంభవుండను",
        "స్మరహర! శ్రీవేంకటేశ సామ్రాజ్యాంబల్",
        "సురుచిరముగ గను పుత్రుడ",
        "ధరలో సత్యాఖ్య నుంటి తథ్యంబు శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 6,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 7,
      "lines_telugu": [
        "శ్రీకంఠ! నాగభూషణ!",
        "చీకాకుల ద్రుంచునట్టి చిన్మయరూపా!",
        "లోకాల నేలు చుండెడి",
        "శ్రీకర! ప్రణతులను నీకు చేసెదను శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 7,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 8,
      "lines_telugu": [
        "నీవే లోకాధీశుడ",
        "వీవే సర్వార్థదాత వీవే ప్రజకున్",
        "భావావేశము గూర్చెద",
        "వీవే తండ్రులకు దండ్రి విమ్మహిని శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 8,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 9,
      "lines_telugu": [
        "నీయాన బూని బ్రహ్మయు",
        "నీయాజ్ఞను గొనుచు హరియు నిఖిల జగాలన్",
        "చేయుచు నుందురు కృతులను",
        "నీయాజ్ఞయె దాల్తు రెల్ల నిర్జరులు శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 9,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 10,
      "lines_telugu": [
        "శిరమున గంగను, చంద్రుని",
        "నురమున సర్పములు, పుర్రె లుత్సవ మనుచున్",
        "సురుచిర సౌఖ్యము లొసగుచు",
        "ధరవారిని గావ నీవు దాల్చెదవు శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 10,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 11,
      "lines_telugu": [
        "సురగణము కోరినంతట",
        "నిరుపమగతి విషము నపుడు నిష్ఠాగరిమన్",
        "సరియంచు ద్రావినాడవు",
        "స్మరహర! నినె గొల్తునయ్య! సతతంబు శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 11,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 12,
      "lines_telugu": [
        "జల మించుక గొని హర! నీ",
        "తలపై చల్లియును బిల్వ తరుపత్రాలన్",
        "నిలిపిన వారల కిలలో",
        "నలఘు సుఖంబులను గూర్తు వనుదినము శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 12,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 13,
      "lines_telugu": [
        "ఆకాశంబున దిరుగుచు",
        "చీకాకులు మహిని గల్గ చేసెడి వారిన్",
        "పోకార్చి ద్రుంచినాడవు",
        "ప్రాకటముగ నాడు, గొనుము ప్రణతులను శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 13,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 14,
      "lines_telugu": [
        "తల్లివి నీవై సతతం",
        "బెల్ల జగంబులను గాతు వేవిధి జూడన్",
        "ఫుల్లాబ్జనేత్ర! శంకర!",
        "సల్లలితానందసుఖద! సకలస్థ! శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 14,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 15,
      "lines_telugu": [
        "శిరముం కంఠము వదనము",
        "కరచరణాదులును నాదు కన్నులు తనువున్,",
        "పురహర! నిను సేవించుటకే",
        "నిరతము నిను గొల్చు బుద్ధి నీవొసగు శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 15,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 16,
      "lines_telugu": [
        "అభిషేకప్రియ! శంకర!",
        "శుభవరదాయక! శుభాంగ! సుందరమూర్తీ!",
        "విభవంబు లొసగు దేవర!",
        "యభయం బిచ్చుచును గావు మనుదినము శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 16,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 17,
      "lines_telugu": [
        "అరుసంబున నీనామము",
        "నిరతము స్మరియించువారి నిఖిలాఘంబుల్",
        "కరుణామయ! నశియించును",
        "ధరపయి ప్రమథాధినాథ! తథ్యంబు శివా!"
