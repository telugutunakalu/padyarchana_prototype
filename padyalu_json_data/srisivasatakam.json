      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 25,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 26,
      "lines_telugu": [
        "బూడిద గాదీ చూర్ణము",
        "పోడిమి సమకూర్చునట్టి పుణ్యప్రదమౌ",
        "సూడిద గావున దాల్చుచు",
        "వేడెద నాయఘము గాల్చి వేయంగ శివా!"
