      "lines_telugu": [
        "ఏకాదశ రుద్రంబులు",
        "నీకర్పించెదను దేవ! నిష్ఠాగరిమన్",
        "చేకొని వాత్సల్యంబున",
        "చీకాకులు ద్రుంచి యొసగు క్షేమంబు శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 60,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 61,
      "lines_telugu": [
        "శివరాత్రి రాత్రి వేళల",
        "భవదీయార్చనము సేతు, భాగ్యము గోరన్",
        "భవబంధము వీడుటకై",
        "భవహర! సద్భక్తి నీయ బ్రార్థింతు శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 61,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 62,
      "lines_telugu": [
        "ఓం కారము నీరూపము",
        "సంకటహర మంత్ర మదియె సతతము దానిన్",
        "శంకాలేశము నందక",
        "పంకేరుహనేత్రమిత్ర! పలికెదను శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 62,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 63,
      "lines_telugu": [
        "నను నీదాసుని బ్రోచెడి",
        "పని నీకనివార్యమైన బాధ్యత గాదా?",
        "ధన మిమ్మని యడిగితినా?",
        "యనుపమ సద్భావ మీయ వదియేల శివా!"
      ],
      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 63,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 64,
      "lines_telugu": [
