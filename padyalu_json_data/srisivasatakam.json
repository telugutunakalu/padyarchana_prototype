      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 64,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 65,
      "lines_telugu": [
        "శివమన మంగళమౌ గద,",
