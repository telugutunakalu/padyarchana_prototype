      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 26,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 27,
      "lines_telugu": [
        "మారేడున మూడాకులు",
        "నీరేజాక్షాప్తమిత్ర! నీ నేత్రమ్ముల్",
        "తీరుగ మూడే కావున",
        "నీరీతిగ వానినందు మీశాన! శివా!"
