      "Chandassu": "కందము",
      "kanda": null,
      "padyam_number": 23,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 24,
      "lines_telugu": [
        "కరిరాజవరద! శంకర!",
        "కరిముఖసన్మానదాత! కరుణాపూర్ణా!",
        "నిరతానందద! సురవర!",
        "సరియగు భావంబు లొసగ సన్నుతులు శివా!"
