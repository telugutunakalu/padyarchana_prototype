{
  "shatakam_title_telugu": "ఆంధ్రనామశేషము",
  "author_telugu": "అడిదము సూరకవి",
  "year": "unknown",
  "literary_form_telugu": "నిఘంటువు",
  "source_url": "https://www.andhrabharati.com/bhAshha/nighaMTuvulu/AMdhranAmashEShamu/index.html",
  "poems": [
    {
      "id": 1,
      "lines_telugu": [
        "శ్రీగౌరీ ప్రియవల్లభ",
        "రాగద్వేషాదిరహిత! - రమ్యచరిత్రా!",
        "యోగిధ్యేయపదాంబుజ!",
        "భోగివలయ! రామచంద్ర-పురవరనిలయా!"
      ],
      "Chandassu": "కందము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 1,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 2,
      "lines_telugu": [
        "అవధరింపుము."
      ],
      "Chandassu": "వచనము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 2,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 3,
      "lines_telugu": [
        "ఆంధ్రనామసంగ్ర-హమునందుఁ జెప్పని",
        "కొన్ని తెలుఁగు మఱుఁగు-లన్నిఁ గూర్చి",
        "యాంధ్రనామశేష-మను పేరఁ జెప్పెద",
        "దీనిఁ జిత్తగింపు - దేవదేవ!"
      ],
      "Chandassu": "ఆటవెలది",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 3,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 4,
      "lines_telugu": [
        "తఱి యజ్జ దనన సమయం",
        "బుఱఁ డనఁగను సరకుసేయ-కుండె ననఁగఁ బే",
        "ళ్లొఱ పగు గణింపఁ డనుటకుఁ",
        "గరిచర్మాంబర! త్రినేత్ర! - గౌరీమిత్రా!"
      ],
      "Chandassu": "కందము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 4,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 5,
      "lines_telugu": [
        "పెంపుసెందెను దామర - తంపరయ్యెఁ",
        "బ్రబలె నెగడెను గొనసాగె - బలిసె పెరిఁగె",
        "ననఁగ రేకెత్తె ననఁగ బే-ళ్ళయ్యె వృద్ధి",
        "బొందె ననుటకు శేషాహి-భూషితాంగ!"
      ],
      "Chandassu": "తేటగీతి",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 5,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 6,
      "lines_telugu": [
        "పేర్మి యర్మిలి మక్కువ - కూర్మి నెమ్మి",
        "నెనరు గాదిలి గారాము - నెయ్యఁ మింపు",
        "ప్రేముడి యనుంగు ముద్దనఁ - బ్రియమునకును",
        "నామధేయంబు లయ్యెఁ బి-నాకపాణి!"
      ],
      "Chandassu": "తేటగీతి",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 6,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 7,
      "lines_telugu": [
        "ఒనఁగూర్చె ననఁగ సమకూ",
        "ర్చె ననన్‌ వీల్పఱిచె ననఁగఁ - జేకూర్చెను నా",
        "ననుకూలపఱిచె ననుటకుఁ",
        "దనరును నామంబులై సు-ధాకరమకుటా!"
      ],
      "Chandassu": "కందము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 7,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 8,
      "lines_telugu": [
        "చరియించె ననుట కాఖ్యలు",
        "తిరిగెను జెరలాడె ననఁగఁ - ద్రిమ్మరె ననఁ గ్రు",
        "మ్మరె ననఁగ మసలె ననఁగాఁ",
        "బుర దానవహరణ! శేష-భుజగాభరణా!"
      ],
      "Chandassu": "కందము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 8,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 9,
      "lines_telugu": [
        "ఆఱుమూఁడయ్యెఁ గచ్చువి-చ్చయ్యె ననఁగ",
        "బెడిసె బుసివోయె ననఁగను - జెడియె ననఁగ",
        "నాఖ్య లగుఁ గార్యవైకల్య-మయ్యె ననుట",
        "కంధకాసురహరణ! రౌ-ప్యాద్రిశరణ!"
      ],
      "Chandassu": "తేటగీతి",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 9,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 10,
      "lines_telugu": [
        "అలజడి నెంజిలి పిమ్మట",
        "సిలు గుత్తలపాటు వంత-సేగి నెగుల్‌ గొం",
        "దల మలమ టడరు గో డు",
        "మ్మలిక వనటఁ గుందు నా న-మరు దుఃఖాఖ్యల్‌."
      ],
      "Chandassu": "కందము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 10,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 11,
      "lines_telugu": [
        "అరిది వెఱం గచ్చెరు వ",
        "బ్బుర మబ్రం బనఁగఁ జిత్ర-మునకుం బేళ్లౌ",
        "సరణికిఁ బేళ్లగుఁ ద్రోవనఁ",
        "దెరువన దారియన బాట- తెన్నన నభవా!"
      ],
      "Chandassu": "కందము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 11,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 12,
      "lines_telugu": [
        "ఐదుపదిచేసె వెనుకముం-దయ్యె జుణిఁగె",
        "వీఁగె వెన్నిచ్చె వెనుకంజ-వేసె ననఁగ",
        "నోహటించె ననంగఁ బే-ళ్లొప్పుచుండు",
        "నాహవపరాఙ్ముఖుం డయ్యె-ననుట కభవ!"
      ],
      "Chandassu": "తేటగీతి",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 12,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 13,
      "lines_telugu": [
        "మోహరించెను దండెత్తె - మొనసె దాడి",
        "చేసెఁ బోటొగ్గెఁ గోల్తలు - చేసె మాఱు",
        "కొనియె దళమెత్తె ననఁగఁ బే-ళ్లొనరుచుండు",
        "నాహవోద్యోగ మొనరించె-ననుట కభవ!"
      ],
      "Chandassu": "తేటగీతి",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 13,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 14,
      "lines_telugu": [
        "ఆహవోన్ముఖతకు నోల-మాసగొనక",
        "పిఱుతివియ కీడఁబో కనఁ - బేళ్లు దనరు",
        "నబ్బెస మొనర్చెఁ గఱచె నా - నభ్యసించె",
        "ననుట కభిధానములు చంద్ర-మావతంస!"
      ],
      "Chandassu": "తేటగీతి",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 14,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 15,
      "lines_telugu": [
        "వేఱొక టనఁ బై పె చ్చన",
        "మాఱుట యిమ్మడి యనన్‌ స-మాహ్వయములు పెం",
        "పాఱును వస్త్వంతరమున",
        "కౌరగకేయూరసహిత-హత! మారజితా!"
      ],
      "Chandassu": "కందము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 15,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 16,
      "lines_telugu": [
        "ఆఱడిపోయెను - బీఱువోయెను రిత్త",
        "వోయెను వీసర-వోయె ననఁగ",
        "నుడివోయెఁ బొలివోయె-సుడివోయె ననఁగను",
        "వ్యర్థ మయ్యె నటంట - కాఖ్య లయ్యెఁ",
        "గడిమి బీరంబు మ-గంటిమి గం డన",
        "విక్రమాహ్వయములై - వెలయుచుండు",
        "నాస్ఫాలన మొనర్చె - ననుటకుఁ జఱచెనా",
        "నప్పళించె ననంగ - నాఖ్య లయ్యె",
        "నొగి వరుస యోలి సొరిది నా-నోజ నాఁగఁ",
        "గ్రమమునకు నాఖ్య లయ్యెను - గాలకంఠ!",
        "కొఱ కొఱఁత తక్కువ వెలితి - కొదవ కడమ",
        "యనఁగ నూనంబునకు నాఖ్య - లై తనర్చు."
      ],
      "Chandassu": "సీసము",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 16,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 17,
      "lines_telugu": [
        "నెట్టుకొనెఁ బాలుపడె నొడి-గట్టె ననఁగఁ",
        "గడఁగెఁ దొడఁగెను జెలరేఁగెఁ - గాలుద్రొక్కెఁ",
        "గవిసెఁ గదిసె ననంగ నా-ఖ్యలయి యొప్పు",
        "నభిముఖుం డయ్యె ననుటకు - నగనివేశ!"
      ],
      "Chandassu": "తేటగీతి",
      "chapter": null,
      "section": "ఆంధ్రనామశేషము - అడిదము సూరకవి",
      "padyam_number": 17,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 18,
      "lines_telugu": [
