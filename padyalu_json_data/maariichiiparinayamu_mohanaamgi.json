      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 31,
      "padyam_number": 32,
      "lines_telugu": [
        "\"జాలము వల్ద,\" టంచు సరసంబుగఁ బల్కిన తండ్రిఁ జూచి నే,",
