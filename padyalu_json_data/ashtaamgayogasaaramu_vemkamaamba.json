{
  "shatakam_title_telugu": "అష్టాంగయోగసారము/పాఠం",
  "author_telugu": "తరికొండ వెంకమాంబ",
  "year": "1955",
  "literary_form_telugu": "ప్రబంధము",
  "source_url": "https://te.wikisource.org/wiki/అష్టాంగయోగసారము/పాఠం",
  "poems": [
    {
      "id": 1,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వన్నె కెక్కిన నందవరచౌడమాంబను",
        "శ్రీనివాసుని విరించిని నుతించి",
        "శ్రీతరిగొండ నృసింహుని కీర్తించి",
        "యా వరాహపురాణ మలఘుపద్య",
        "కావ్యంబుఁ జేసి యోగములందు విస్తార",
        "ముగ రచించితిఁ గాన మొనసి సభల",
        "నీ యోగమర్మంబు లెఱిఁగి చెప్పం దగు",
        "ననుచుఁ గొందఱు వల్కి రందువలన",
        "నా వరాహపురాణమం దమరు యోగ",
        "సరణి నీవలఁ దీసి యెచ్చటను భక్తి",
        "యోగమే యుంచి యష్టాంగయోగసార",
        "మనఁగ నీకృతి రచియింతు నార్యులార॥"
      ],
      "Chandassu": "సీసము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 2,
      "padyam_number": "unknown",
      "lines_telugu": [
        "మదపచారంబు క్షమించి తత్కథాక్రమం బెట్లన్నను.",
        "చం॥ వెలయు పురాణధర్మములు వేడ్కగ సూతుఁడు దెల్ప శౌనకా",
        "దులు విని యొక్కనాఁడు బహుదుస్తర యోగవిధానమర్మముల్",
        "దెలుపుమటన్న నా ఘనుఁడు ధీరతమీరఁగ నమ్మునీంద్రులన్",
        "గలయగఁ జూచి యిట్లనియె గౌరవమొప్ప గురుందలంచుచున్॥"
      ],
      "Chandassu": "వచనము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 3,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వినుడి సంయములార మును భూమిదేవి కీ",
        "యష్టాంగయోగంబు లా వరాహ",
        "దేవుండు దయ నుపదేశించిన విధంబు",
        "సాత్యవతేయుఁ డాశ్చర్యముగను",
        "విని నాకుఁ జెప్పినవిధము మీకెఱిఁగింతు",
        "నారీతు లెట్లన్న నమర మీకుఁ",
        "జెప్పెద నొకనాఁడు శ్వేతకిటిస్వామి",
        "నీక్షించి ప్రణమిల్లి యిష్టముగను",
        "ధారుణీదేవి యడుగఁగా దయను బోత్రి",
        "వైష్ణవాచారధర్మముల్ వరుసగాను",
        "జెప్పగా విని సంతోషచిత్త యగుచు",
        "నల మహీకాంత విభు నిట్టు లడుగఁ దొణఁగె॥"
      ],
      "Chandassu": "సీసము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 4,
      "padyam_number": "unknown",
      "lines_telugu": [
        "దేవా! జ్ఞానవిరక్తిభక్తులను సాధింపన్ ద్విజుల్ నిత్యమున్",
        "ధీవిశ్రాంతి నొసంగు మోక్షగతియందే లక్ష్యమున్ నిల్పుచున్",
        "గావింపందగినట్టి సత్క్రతువులన్ గావింపగావచ్చునో",
        "పోవీడం దగునో యథార్థముగఁ దత్పుణ్యస్థితిన్ జెప్పవే॥"
      ],
      "Chandassu": "శార్దూలవిక్రీడితము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 5,
      "padyam_number": "unknown",
      "lines_telugu": [
        "అని యడిగిన భూదేవిని జూచి వరాహస్వామి యిట్లనియె.",
        "బ్రహ్మసాయుజ్యప్రాప్తి విధానము"
      ],
      "Chandassu": "వచనము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 6,
      "padyam_number": "unknown",
      "lines_telugu": [
        "భాసురవిజ్ఞాన భక్తివైరాగ్యముల్",
        "గలిగినవారైనఁ గర్మములను",
        "విడువగాఁ దగ దది వేదోక్తమార్గంబు",
        "గాన సల్పందగుఁ గ్రమముగాను",
        "స్నానసంధ్యాదులు సవనముల్ నిజశక్తి",
        "కొలఁది సల్పందగుఁ గోర్కె విడచి",
        "హరి కర్పితం బని యాచరించిన హరి",
        "సంతుష్టుఁడగు నదే సత్ఫలంబు",
        "గనుక విప్రులు వేదమార్గక్రమమున",
        "జన్నములు సేయుచున్న నీశ్వరుఁడు మెచ్చి",
        "యిష్టఫలములఁ దా వారి కిచ్చుచుండు",
        "నందుచే జన్నములొనర్తు రార్యులెల్ల॥"
      ],
      "Chandassu": "సీసము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 7,
      "padyam_number": "unknown",
      "lines_telugu": [
        "ఇవ్విధంబున మదాజ్ఞాధారులై నిష్ణామసత్కర్మంబుల నాచరింపవలయు నట్లాచరింపక మదాజ్ఞోల్లంఘనంబుఁ జేసినవారు దోషయుక్తు లగుదురు గావున సద్రాహ్మణులు యజనాదిషట్కర్మంబు లాచరించుదురు. అందుఁగొందఱు బ్రహ్మచర్య, గార్హస్థ్య, వానప్రస్థధర్మంబు లాచరించి, తత్త్వజ్ఞులై సన్యసించి కర్మముక్తులై ప్రణవోచ్చారణంబు సేయుచు నీశ్వరధ్యాననిష్ఠాగరిష్టులై మఱువక నారాయణస్మరణంబుఁ జేయుచు నివ్విధంబున సన్యాసవిధిఁ గొన్నియబ్దంబు లాచరించి పరిపూర్ణజ్ఞానోదయంబైన",
        "పిమ్మట విధివత్తుగా దండకమండలువుల విడిచి యవధూతాశ్రమంబు నంగీకరించి శీతోష్ణసుఖదుఃఖాదిద్వంద్వాతీతులై సచ్చిదానందనిత్యపరిపూర్ణబ్రహ్మానుసంధానంబు సేయుచుండవలయు నట్లు చేసినవారు బ్రహ్మసాయుజ్యంబు నొందుదురని చెప్పి వరాహస్వామి మఱియు నిట్లనియె.",
        "బ్రహ్మద్వైవిధ్యము"
      ],
      "Chandassu": "వచనము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 8,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వెలఁది బ్రహ్మము రెండు విధములై యుండుఁ బ",
        "రాపరంబు లనంగఁ బ్రబలు నందుఁ",
        "బర మక్షరంబు నపరమౌ క్షరం బీ క్ష",
        "రంబు జీవుం డక్షరంబు విమల",
        "కూటస్థుఁడనఁబడు, పాటింపఁ బరమాత్ముఁ",
        "డతఁడె, పరేశ్వరుం డతఁడె గురుఁడు",
        "పురుషోత్తముఁడు సర్వపూర్ణుఁడౌ బ్రహ్మాంశ",
        "జుండనఁదగిన జీవుం డవిద్య",
        "నంటి పరిమితిలేని దేహంబులందుఁ",
        "జొచ్చి వెడలుచు బహుమోహశోకవార్డు",
        "లందు మునుఁగుచుఁ దేలుచు నహముఁ బెంచి",
        "భూరికర్మంబు లొనరించి పుట్టు గిట్టు॥"
      ],
      "Chandassu": "సీసము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 9,
      "padyam_number": "unknown",
      "lines_telugu": [
        "కామముచేఁ గ్రతుప్రముఖకర్మము లొప్పుగ నాచరించి సు",
        "త్రామపురాదిలోకములఁ దక్కగఁజేరి సుఖంబు లొంది యం",
        "దేమఱియున్న పుణ్యతతు లెప్పుడు నాశమునొందు నప్పుడే",
        "భూమినిఁ బుట్టి క్రమ్మఱను బోవుచు వచ్చుచునుందు రెప్పుడున్॥"
      ],
      "Chandassu": "ఉత్పలమాల",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 10,
      "padyam_number": "unknown",
      "lines_telugu": [
        "ఘనతరములైన యోగప్రకారములను",
        "దేవ సత్కృపతో నాకుఁ దెలుపవలయు",
        "ననుచుఁ బ్రార్ధింప ముదమంది యా వరాహ",
        "దేవుఁ డిట్లనె నాభూమిదేవి కపుడు॥",
        "యోగమార్గక్రమము"
      ],
      "Chandassu": "గీతము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 11,
      "padyam_number": "unknown",
      "lines_telugu": [
        "యోగమార్గక్రమం బెట్లనిన గురూపదేశక్రమంబుగా యమనియమాసన ప్రాణాయామ ప్రత్యాహార ధ్యానధారణ సమాధులనియెడి యష్టాంగయోగంబు లభ్యసింపపలయు నందు యమం బెట్టిదనిన.",
        "యమస్వరూపము"
      ],
      "Chandassu": "వచనము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 12,
      "padyam_number": "unknown",
      "lines_telugu": [
        "జగతి నహింసయు సత్య మస్తేయంబు",
        "బ్రహ్మచర్యం బార్జవంబు క్షమయు",
        "నతిదయ ధృతి మితాహారముల్ శౌచంబు",
        "నీపది యమము లవెట్టు లనిన",
        "సకలజీవులకుఁ గ్లేశంబు బుట్టింపకు",
        "న్నట్టిచంద మహింస యనగఁ బరగు",
        "నవని నందఱ కిష్టుఁడై దబ్బరాడకు",
        "న్నట్టి చందము సత్య మన్యధనముఁ",
        "గోరి మాయలఁబన్ని కైకొనఁదలంప",
        "కుండు టస్తేయ మనఁబడు నొరులసతుల",
        "మాతృభావముగాఁ జూచుమతము బ్రహ్మ",
        "చర్యయన నొప్పుచుండునో సరసిజాక్షి॥"
      ],
      "Chandassu": "సీసము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 13,
      "padyam_number": "unknown",
      "lines_telugu": [
        "సారదయ భూతమైత్రి, యార్జవమనంగ",
        "నకుటిలత్వ మగున్ క్షమయనఁగ నోర్పు",
        "ధృతి యనఁగ ధైర్యమనఁదగు, మితసుభుక్తి",
        "యనగ మితభోజనము, శౌచమనఁగ శుద్ధి॥"
      ],
      "Chandassu": "గీతము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 14,
      "padyam_number": "unknown",
      "lines_telugu": [
        "యమం బీపదివిధంబులఁ జెప్పందగు నింక నియమంబు లెయ్యవి యనిన.",
        "నియమస్వరూపము",
        "యోగశాస్త్రరతియు, సత్పాత్రదానంబును, సంతోషంబును, లజ్జయు, వ్రతంబును, మతియును, ఆస్తిక్యంబును, ఈశ్వరార్చనంబును, దపంబును, జపంబును, నననొప్పు నీ దశవిధంబులైన నియమంబులందు, వాదాస్పదశాస్త్రంబు లుదరపోషణార్థంబని నిరసించి, మోక్షప్రదశాస్త్రంబు లభ్యసించుట యోగశాస్త్రరతియగు. తనకుఁ బ్రాపంబైన ధనంబు గురుద్విజార్థులకు సమర్పించుచుండుట పాత్రదానంబగు. లాభాలాభ శుభాశుభ సంయోగవియోగ మానావమాన స్తుతినిందాదుల మోదఖేదంబులు లేక యుండుటె సంతోషంబగు. సుజనసాంగత్యంబువలనఁ దన దుర్గుణంబులఁ దాఁ దలఁచి తన్ను దా నిందించికొని దుర్గుణంబుల మాని సుగుణంబు లభ్యసించుటె లజ్జయగు. తా సంకల్పించి చేయు మోక్షసాధనంబు విడువక యాచరించుట వ్రతంబగు. తాఁజేయు యోగంబునకు రోగదారిద్ర్యసంశయ శాస్త్రవాద రసవాద దుర్జనసహవాసాది విఘ్నంబులు వచ్చినప్పటికిని జలింపకుండుటే బుద్ధియగు. మతభేదపురాణేతిహాసాది సద్గ్రంథంబులను శ్రద్ధతోఁ జూచి సారార్థగ్రహణంబుఁ జేయుటే ఆస్తిక్యంబగు. అతితేజోమయంబైన యీశ్వరస్వరూపంబును గురుముఖంబుగా నెఱిఁగి హృత్కమలమందు మనంబున ధ్యానించి పూజించుటే యీశ్వరార్చనంబగు. గురువాక్యంబు సత్యంబుగా నమ్మి చెప్పిన నియమంబు తప్పక కష్టంబున కోర్చి నడపుటె తపంబగు. జప్యాజప్యంబులయందుఁ దనకు గురుం డుపదేశించినమంత్రంబు నిశ్చలుండై విడువక జపించుటే జపంబగు. నీ పదియు నియమంబులగు నిట్టి యమనియమంబు లిరువదియు నంతశ్శుద్ధిప్రదంబులగుం గావున వీని నభ్యసించి యంతశ్శుద్ధి నొంది కీటాది జంతువులు మెదలకుండునట్టి విజనస్థలంబునందుఁ జేలాజినకుత్తరోత్తరంబుగా నాసనంబు నిర్మించి యంద ఆసనంబు లభ్యాసంబు సేయవలయు నవ్విధం బెట్లనిన. ఆసనములు"
      ],
      "Chandassu": "వచనము",
      "bhavam": null,
