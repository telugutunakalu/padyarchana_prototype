  "poems": [
    {
      "lines_telugu": [
        "శివనామ జపము చేయుచు",
        "శివరాత్రిని గడుప నేను శివశతకంబున్",
        "శివ సంకల్పము తోడుత",
        "కవనార్చనమనగ నీకు గావింతు శివా!"
      ],
      "Chandassu": "కందము",
      "padyam_number": null,
      "bhavam": null,
      "prathipadartham": null,
      "id": 1,
      "kanda": null
    },
    {
      "lines_telugu": [
        "ముందుగ గణపతిఁగొలిచియు",
        "అందంబగు నమ్మ చరణమంటియుఁ దలతో",
        "కందములే కుందములన",
        "పొందిక పద్యములఁగూర్చి పొగడెదను శివా!"
      ],
      "Chandassu": "కందము",
      "padyam_number": null,
      "bhavam": null,
      "prathipadartham": null,
      "id": 2,
      "kanda": null
    },
    {
      "lines_telugu": [
        "చిన్మయమగు చైతన్యము",
        "ఉన్మనియౌ కళగ లోన నుద్దీప్తంబై",
        "మన్మనమున భాసింపగ",
        "తన్మయతను నిన్ను నేను తలచెదను శివా!"
      ],
      "Chandassu": "కందము",
      "padyam_number": null,
      "bhavam": null,
      "prathipadartham": null,
      "id": 3,
      "kanda": null
    },
    {
      "lines_telugu": [
        "ఓంకారము నీ రూపము",
        "హ్రీంకారము నీదు శక్తి హ్రీంబీజముతో",
        "ఓంకారముచ్చరింపగ",
        "ఓంకారము మిగుల శక్తియుత మౌను శివా!"
      ],
      "Chandassu": "కందము",
      "padyam_number": 1,
      "bhavam": null,
      "prathipadartham": null,
      "id": 4,
      "kanda": "పంచాక్షర పద్యపంచకము"
    },
    {
      "lines_telugu": [
