{
  "shatakam_title_telugu": "భృంగరాజ మహిమము",
  "author_telugu": "దాసు శ్రీరాములు",
  "year": "1902",
  "literary_form_telugu": "ప్రబంధము",
  "source_url": "https://te.wikisource.org/wiki/భృంగరాజ మహిమము",
  "poems": [
    {
      "id": 1,
      "padyam_number": "unknown",
      "lines_telugu": [
        "ఆదిశక్తి స్వరూపాంచ | నిర్జరావనతత్పరామ్",
        "ఆరోగ్యదాయినీంవందే | భామరీంలోకపోషణీమ్",
        "భృంగరాజ స్తవము"
      ],
      "Chandassu": "శ్లోకము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 2,
      "padyam_number": "unknown",
      "lines_telugu": [
        "భ్రామరీపద సంభూతం గంగాతటనివాసినం",
        "భృంగరాజం నమామ్యద్య | సర్వరోగనివారణం॥",
        "ఆదినాధస్తవము"
      ],
      "Chandassu": "శ్లోకము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 3,
      "padyam_number": "unknown",
      "lines_telugu": [
        "ఆదినాధం మహాసిద్ధం| చంపకారణ్యవాసినం",
        "లోకసంచారిణం సాధుం|మహావైద్యవిశారదం॥",
        "నవనాధ స్తవము",
        "శ్లో౹౹ భావయేనవనాధంచ నిత్యంవననివాసినం",
        "లోకోపకారిణం వందే|మమరోగాపను త్తయే"
      ],
      "Chandassu": "శ్లోకము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 4,
      "padyam_number": "unknown",
      "lines_telugu": [
        "శ్రీకరముగ నవనాధుడు",
        "ప్రాకటగతి చెప్పినట్టి పరవైద్యమునే",
        "నేకతమున దెనిగింతును",
        "మాకేవల భృంగరాజు మహిమము వేడ్కన్"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 5,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వె. భృంగరాజ శక్తి సంగతియేమందు",
        "సంగతాపముల భయంబులడచు",
        "లింగమూర్తి తలను బొంగారుచున్నట్టి",
        "గంగ యందపుట్టె గాదె తల్లి"
      ],
      "Chandassu": "ఆటవెలది",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 6,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వె. చెలగి భృంగరాజ సేవనంబువ నెన్న",
        "దరముగాని రోగ తతియడంగు",
        "బురుషునకు దలంవ బూర్ణబలంబిచ్చు",
        "ననుచు జెప్పె సిద్ధుడాదరమున.॥",
        "ఈ గుంటగలగర మొక్క యెంతటి కఠినమైన రోగములనయినను మాన్పును, శరీరమునకు మంచి బలముపట్టును."
      ],
      "Chandassu": "ఆటవెలది",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 7,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వె. గుంటకల్గ రొడలి పుంటిని గింటిని",
        "బంటుతనముగిల్లి బాగోనర్చు",
        "ఒడలివ్యాధులెల్ల సడలి బలముకల్గు",
        "నంటురోగనముదయంబు విడుచు౹౹"
      ],
      "Chandassu": "ఆటవెలది",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 8,
      "padyam_number": "unknown",
      "lines_telugu": [
        "గాలిసౌరకుండ నొకబు ర్రగట్టిసేని",
        "కర్షమాత్రంబు తేనెతో గల్పికొనుచు",
        "ననవరతమును నరుడు జీవన ముజేయ",
        "వ్యాధిరాదని సిద్ధుండు పలికే నిజము."
      ],
      "Chandassu": "గీతము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 9,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వాతరోగంబులకు నిదివై రిసుమ్ము",
        "ప్రాతబెల్లముతో గూర్చి పరగనూరి",
        "రేగుపండ్లంత మాత్రలు రోగికిడిన",
        "శూలలన్నియు గడియలో దూలిపోవు"
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 10,
      "padyam_number": "unknown",
      "lines_telugu": [
        "గుంటగలగర మొలకల బండుతనము",
        "వింటి నీముఖమున నేడు వీనులలర",
        "కొంటెలకు నెల్ల బుట్టెడు నంటు రుజలు",
        "దీనితో మానువిధమును దెలుపు మనఘ."
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 11,
      "padyam_number": "unknown",
      "lines_telugu": [
        "మిరియపు గింజలు తొమ్మది",
        "వరుసం జూర్ణముచేసి వదలక యందు౯",
        "వరభృంగదళ నవకము౯",
        "బెరిమె మెదిపి తినిన జిలిపి వెతబడగించున్."
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 12,
      "padyam_number": "unknown",
      "lines_telugu": [
        "పిప్పళ్ళును మిరియంబులు",
        "నొప్పుగ శొంఠియును మోడి యొగివసకరకల్",
        "తప్పక సమములు పొడిగా",
        "గుప్పిగలగర రసమునను గొనుడి రుజలకుస్"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 13,
      "padyam_number": "unknown",
      "lines_telugu": [
        "గుటగుటవేళ్ళ చెక్క యును గోరిక మీరగిదెచ్చి పిమ్మటన్",
        "చటుల తరంపు కల్గరసంబున మర్దనిజేసి మాత్రలన్",
        "దటవిటలేకయొక్కోకటి నాలుగు గుంజలయెత్తు చొప్పునన్",
        "తటుకున రోగికిచ్చినను తందర సన్ని హరించు వేగమే౹౹"
      ],
      "Chandassu": "చంపకమాల",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 14,
      "padyam_number": "unknown",
      "lines_telugu": [
        "శొంఠి పిప్పలి మిరియాలు సొరిదిగటుక",
        "రోహిణియు గంటుభారంగి రూఢి మునగ",
        "చెక్కయును గరకపప్పరజేర్చి యుప్పి",
        "చెక్క చూర్ణంతో బుజేర్చి చెంగి తముల",
        "పాకురసమును గలగరయాకురసము",
        "బోసి యామద్వయమ్ము సంపూర్ణముగను",
        "మర్దనముజేసి బదరప్రమాణమాత్ర",
        "లొనర గావించి రోగి తాదినినయేని",
        "సన్నిపాతంబు లన్నియు సమసిపోవు.॥"
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 15,
      "padyam_number": "unknown",
      "lines_telugu": [
        "యందుసిందూరమును గల్పియంతసేపు",
        "మర్దనముచేసి గుంజాప్రమాణమయిన",
        "మాత్రలను దిన జ్వరములు మానువేగ",
        "ననుచు సిద్ధుడు వచియించె అద్భుతముగ."
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 16,
      "padyam_number": "unknown",
      "lines_telugu": [
        "కండచక్కెర మిరియాలు గలయనూరి",
        "గుంటగల్గర పసరులో గూర్చి కల్పి",
        "మూడుతులముల యెత్తును మొనసిత్రాగ",
        "నండశూలలు మూనాళ్ళ కడగిపోవు"
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 17,
      "padyam_number": "unknown",
      "lines_telugu": [
        "అండశూలలనెల్ల ఖండించు విధమును",
        "తాల్మితో నుడివెద దనరవినుము",
        "భృంగరాజంబున బేర్మిరసము దీసి",
        "కటుకరోహిణినందు గలయనూరి",
        "తేనెను దానిలో దెల్లంబుగా నుంచి",
        "తర్వాత నార్ద్రవస్త్రమున రాచి",
        "అండదేశము చుట్టి కొండొక సేవుంచి",
        "పండునిప్పులమీద బరగ గాచి",
        "మూడుదినముల నీరితి మొనసిచేయ",
        "వాపడంగును శమియించు వడిగ శూల",
        "సుఖముగానుండు సండముల్ శుద్ధములగు",
        "ననుచు సిద్ధుండు వచియించే నద్భుతముగ."
      ],
      "Chandassu": "సీసము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 18,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వెలిగారము పొంగించియు",
        "కలిలోసన్ భృంగరసము కల్పియు వేగన్",
        "తెలుపగు ఫేవముతోడన్",
        "సలువుగ ద్రావింప శూల నటనలడంచున్"
      ],
      "Chandassu": "కందము",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 19,
      "padyam_number": "unknown",
      "lines_telugu": [
        "ఆరతులము కట్కరోహిణి సరగసూరి",
        "మిరియముల చూర్ణమును దానమెళగించి",
        "నాల్గుతులముల పసరులో నల్ని కల్పి",
        "రోగికిచ్చిన శూలలు డాగిపోవె"
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 20,
      "padyam_number": "unknown",
      "lines_telugu": [
        "భృంగరాజపు కొనలను సంగతముగ",
        "తురగసంఖ్యను గొనితెచ్చి పరగజేర్పి",
        "యేడు మిరియాలతో మూడునాడులు దిన",
        "చురుకు రోగంబులు దొలగి సుఖమునిచ్చు",
        "గుంటగలగరాకులు ఏడుకొనలతోనున్నవి,మిరియాలు ఏడు కల్పి సేవించిన యెడల చురుకు సెగలు మానును."
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 21,
      "padyam_number": "unknown",
      "lines_telugu": [
        "ఏడుదినములు సేవింపనెల్ల గతుల",
        "పొక్కులు సవాయి చచ్చును మిక్కిలిగను",
        "గ్రచ్బు జేసెడి రోగముల్ కదలి పోవు",
        "ననుచు సిద్ధుండు వచియించే నద్భుతముగ"
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 22,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వె. భృంగరాజ రసము పొలుపొందగా దీసి",
        "తుమ్మియాకు రసము తోడుజేసి",
        "పిప్పలందు నూరి తెప్పన బెట్టిన",
        "అక్షిమాంసదోష మణగిపోదె."
      ],
      "Chandassu": "ఆటవెలది",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 23,
      "padyam_number": "unknown",
      "lines_telugu": [
        "వె. కలగరాకు రసము గారవంబునతీసి",
        "గారపండుజిగట గలయు నూరి",
        "కన్నులందు బెట్ట కంపదోషమడంగు",
        "నెలకు పూలుదొలగు నెమ్మి హెచ్చు."
      ],
      "Chandassu": "ఆటవెలది",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 24,
      "padyam_number": "unknown",
      "lines_telugu": [
        "గీ శ్రవణరంధ్రబులను నొక్క జాము బిడిచి",
        "చూడనెంతటి సర్పంబు గాడగరచి",
        "బాధపడుచున్న దొలగు నిర్భయతబొసగు",
        "వృశ్పికవిషంబు దొలగించు వేరిపసరు"
      ],
      "Chandassu": "తేటగీతి",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 25,
      "padyam_number": "unknown",
      "lines_telugu": [
