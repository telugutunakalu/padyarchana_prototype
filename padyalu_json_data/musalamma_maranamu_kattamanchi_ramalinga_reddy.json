{
  "shatakam_title_telugu": "ముసలమ్మ మరణము",
  "author_telugu": "కట్టమంచి రామలింగారెడ్డి",
  "year": "unknown",
  "literary_form_telugu": "ఖండకావ్యము",
  "source_url": "https://www.andhrabharati.com/kAvyamulu/musalamma_maraNamu/index.html",
  "poems": [
    {
      "id": 1,
      "lines_telugu": [
        "చెన్నపురి క్రైస్తవకళాశాలకుం జేరిన శ్రీమదాంధ్రభాషాభిరంజనీ\r\nసమాజమునఁ దత్పోషకులగు రాజశ్రీ, సమర్థి రంగయ్యసెట్టిగారిచే నూతనముగ స్థాపింపఁబడిన\r\nబహుమానకావ్య పద్ధతి ననుసరించి ఈ కావ్యము రచియించితిని. ఇయ్యది పారితోషికమునకుఁ దగినదని\r\nయామోదించినందులకు వారి కనేక వందనము లర్పించుచున్నాఁడను."
      ],
      "Chandassu": "వచనము",
      "chapter": "ముసలమ్మ మరణము",
      "section": "మొదటికూర్పునకు ముఖపత్త్రము",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 2,
      "lines_telugu": [
        "ఒకానొక త్రిలింగదేశీయునిచే వ్రాయబఁడి బ్రౌన్‌ దొరగారిచేఁ బ్రకటింపఁబడిన 'అనంతపుర చరిత్రము'\r\nఅను గ్రంథమునుండి యిందలి కథం గైకొంటిని. అయినను గొన్నియెడల రసాధిక్యమునకై నూతనకల్పనలు చేసినాఁడ."
      ],
      "Chandassu": "వచనము",
      "chapter": "ముసలమ్మ మరణము",
      "section": "మొదటికూర్పునకు ముఖపత్త్రము",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 3,
      "lines_telugu": [
        "అనంతపురమునకు సమీపమున బుక్కరాయ సముద్రము నేఁటికి ఉన్నది. ఆ యూరి చెఱువుకట్టకు\r\n'ముసలమ్మకట్ట' యనియే పేరు. అచ్చట నేఁటేఁట జనులందఱుఁ బొంగళ్ళుపెట్టుచు ముసలమ్మను\r\nగ్రామదేవతగాఁ గొలుచుచున్నారు. ఆ పల్లెలో నీ విషయమైన శిలాశాసనమున్నదఁట. ఈ గ్రంథము\r\nరచియించుటకు బూర్వమే నాకీ సంగతులు తెలిసియుండిన నే నచ్చటికి బోయి సర్వమును జూచి తత్‌\r\nప్రదేశస్వభావవర్ణన మిక్కుటముగఁ జేసియుందును. అనంతపురములోఁ గొన్ని సంవత్సరములు\r\nనివసించిన నా మిత్రులగు నారాయణస్వామి నాయనగారి యింట నే నీపుస్తకమును జదివినప్పుడు\r\nవారే తద్‌గ్రామ సంబంధ విషయములం జెప్ప నా కపరిమితాశ్చర్యమైనది."
      ],
      "Chandassu": "వచనము",
      "chapter": "ముసలమ్మ మరణము",
      "section": "మొదటికూర్పునకు ముఖపత్త్రము",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 4,
      "lines_telugu": [
        "ఈచిన్నిపొత్తము ముఖ్యముగా స్త్రీలకొఱకుఁ జేయబడినది. వారి కుపయుక్తముగా నొప్పినయెడల నా\r\nప్రయాస సఫలతనొందినట్టే."
      ],
      "Chandassu": "వచనము",
      "chapter": "ముసలమ్మ మరణము",
      "section": "మొదటికూర్పునకు ముఖపత్త్రము",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 5,
      "lines_telugu": [
        "ఈ కార్యమును నేఁ జదువగా విని కొన్ని తప్పుల సవరించినందులకు బ్రహ్మశ్రీ, కొక్కొండ వెంకటరత్నము\r\nపంతులుగారికిని, ముద్రాపణకార్యమును నిర్వహించిన మామక మిత్రులగు కందుకూరు మల్లికార్జునాచారిగారికిని,\r\nవందనము లర్పించెదను. మఱియు నెన్నఁడు నన్నుఁజూచి యెఱుఁగనివారయ్యు మల్లికార్జునాచారిగారి\r\nప్రేరణచే విశేష కాలవ్యయమున కోర్చి యీ గ్రంథమును శ్రద్ధతోఁ జదివి యనేక విషయములను\r\nసూచించిన దయాశాలురగు బ్రహ్మశ్రీ దుర్భా సుబ్రహ్మణ్యశర్మగారికి మత్కృతజ్ఞతాసూచక\r\nనమస్కారములు. పదిమందికిఁ దెలియునట్లు నివేదింపఁ దరుణమబ్బినందున కెంతయు సంతసంబయ్యెడి."
      ],
      "Chandassu": "వచనము",
      "chapter": "ముసలమ్మ మరణము",
      "section": "మొదటికూర్పునకు ముఖపత్త్రము",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 6,
      "lines_telugu": [
        "ఆర్యులారా! నేను నిశ్చయముగఁ బండితుఁడనుగాను. మరి పామరుఁడను. బాలుఁడను కావున,\r\nనిం దెవ్వియేని దోషములున్నఁ జూపి ననుంగృతార్థునిఁ జేయ మీ రెల్లరుఁ బ్రార్థితులు."
      ],
      "Chandassu": "వచనము",
      "chapter": "ముసలమ్మ మరణము",
      "section": "మొదటికూర్పునకు ముఖపత్త్రము",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 7,
      "lines_telugu": [
        "ఇట్లు విన్నవించు",
        "సకలజనవిధేయుఁడు,",
        "కట్టమంచి రామలింగారెడ్డి",
        "మద్రాసు,",
        "క్రైస్తవ కళాశాల",
        "మార్చి, ౧౯౦౦"
      ],
      "Chandassu": "వచనము",
      "chapter": "ముసలమ్మ మరణము",
      "section": "మొదటికూర్పునకు ముఖపత్త్రము",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 8,
      "lines_telugu": [
        "శ్రీమత్కటుమంచీ పుర",
        "ధామా! శుభనామ! దేవతాకోటి కిరీ",
        "టామల పాదాంభోజా!",
        "కామాక్షీ సహిత! సౌఖ్య కర! బాల్యేశా."
      ],
      "Chandassu": "కందము",
      "chapter": "ముసలమ్మ మరణము",
      "section": "ఉపక్రమణిక",
      "padyam_number": 1,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 9,
      "lines_telugu": [
        "శ్రీలఁ జెలంగు లోకముల సృష్టి యొనర్ప విరించియై, తగం",
        "బాలన సేయ విష్ణువయి, వాని లయింపఁగ శూలపాణియై,",
        "లీల సరస్వతిన్‌ గలిమి లేమను బార్వతిఁ గూడి వెల్గు ది",
        "వ్యాలఘు శాంత తేజము జనౌఘమహార్తి హరించుఁ గావుతన్‌."
      ],
      "Chandassu": "ఉత్పలమాల",
      "chapter": "ముసలమ్మ మరణము",
      "section": "ఉపక్రమణిక",
      "padyam_number": 2,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 10,
      "lines_telugu": [
        "శ్రీల నొసంగె యక్షున, కరిప్రకరంబుల భండనంబునం",
        "గూలఁగ నేయఁ జక్రమిదె కొమ్మని శ్రీహరి కిచ్చె, నిచ్చె గౌ",
        "రీ లలనా లలామకు శరీరము నం దొక యర్థ, మిచ్చె గో",
        "పాలున కన్యభాగ, మిటు బాపురె సర్వముఁ గోలుపోయియున్‌."
      ],
      "Chandassu": "ఉత్పలమాల",
      "chapter": "ముసలమ్మ మరణము",
      "section": "ఉపక్రమణిక",
      "padyam_number": 3,
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 11,
      "lines_telugu": [
        "సకల జగములకును సాక్షియై, కర్తయై,",
        "విభుఁడు నై, శివుండు వెలుఁగుఁగాదె;",
        "యిల్లు లేని వాని కెల్ల గృహమ్ములు",
        "సొంత మయ్యె ననెడు సూక్తి దోఁప."
      ],
      "Chandassu": "గీతము",
      "chapter": "ముసలమ్మ మరణము",
