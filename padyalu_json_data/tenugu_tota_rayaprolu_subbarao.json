{
  "shatakam_title_telugu": "తెనుగు తోట",
  "author_telugu": "రాయప్రోలు సుబ్బారావు",
  "year": "1913",
  "literary_form_telugu": "ప్రబంధము",
  "source_url": "https://te.wikisource.org/wiki/తెనుగు తోట",
  "poems": [
    {
      "id": 1,
      "lines_telugu": [
        "యభినవ వికాస దీపన మభినయించు;",
        "తిన్ననిపథంబు బట్టె యాత్రిక జనంబు",
        "లేచి రా వమ్మ ! మా తల్లి ! లేచి రమ్ము",
        "తెనుగుతోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 2,
      "lines_telugu": [
        "ఆలసించిన నిలువరు హర్ష వశలు,",
        "ముందుబోయిన నంద రో సుందరాంగి!",
        "లేచి రా వమ్మ ! మా తల్లి! లేచి రమ్ము !",
        "తెనుగుతోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 3,
      "lines_telugu": [
        "వినబడు నుషఃకలాపకీర్తనలె కడల,",
        "పొడుచుచుండె తేజఃకళాపుంజ మెదుర",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచి రమ్ము !",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 4,
      "lines_telugu": [
        "పోవ నుంకింతు రా పుణ్యమూర్తి కడకు,",
        "తల్లి బిడ్డల భావబంధములు పెనగ",
        "లేచి రా వమ్మ! మాతల్లి ! లేచి రమ్ము !",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 5,
      "lines_telugu": [
        "ఎక్క డెక్కడ నుండియో చక్క వచ్చి",
        "వ్రాలుచున్నవి పిట్టలు వేలు వేలు;",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచి రమ్ము.",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 6,
      "lines_telugu": [
        "కంచె దీసి త్రోవలు సేయు వంచకులను,",
        "తెలియగా లేడు తోట నేవలన గాచు",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచి రమ్ము !",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 7,
      "lines_telugu": [
        "కలకల కషాయ మాధురీ విలసనముల",
        "నాడు నీబిడ్డపులుగుల నరయ వమ్మ;",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచి రమ్ము !",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 8,
      "lines_telugu": [
        "అక్కచెల్లెండ్ర రాగము లతిశయింప",
        "తల్లి తోటల గాపాడ వెళ్ళ రమ్మ!",
        "లేచి రా వమ్మ! మాతల్లి! లేచిరమ్ము!",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 9,
      "lines_telugu": [
        "వలద నెడివార లెవ్వ రవ్యక్త మతులు,",
        "ఆదరింపని వా రెవ్వ రాడువాండ్రు,",
        "లేచి రా వమ్మ ! మాతల్లి రమ్ము.",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 10,
      "lines_telugu": [
        "నిడుముత్యాలశాలల నీటు సూపి",
        "వాసి జూరాడినట్టి నీభాగ్య మేది?",
        "లేచి రావమ్మ! మాతల్లి! లేచి రమ్ము!",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 11,
      "lines_telugu": [
        "సూటిగా పొమ్మటంచును తోటదారి",
        "చూపు చున్నది సుత నిక్కి సూచుచుండ,",
        "లేచి రా వమ్మ! మాతల్లి! లేచి రమ్ము!",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 12,
      "lines_telugu": [
        "నావలో బూలు శోషిల్లి నవయ గలవు.",
        "మాతృపూజాముహూర్త మేమఱిరొ యేమొ",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచి రమ్ము !",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 13,
      "lines_telugu": [
        "స్వాదురాగతరంగ మనాదరమున",
        "కోనలను లంకలను గయిగొనునె శాంతి ?",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచి రమ్ము!",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 14,
      "lines_telugu": [
        "చ్యుతయశస్వినిపయి నల్క సూపగలవె",
        "సువిమలము లైన భానుభానువులు తల్లి !",
        "లేచి రావమ్మ ! మాతల్లి ! లేచిరమ్ము !",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 15,
      "lines_telugu": [
        "పూలు తాంబూలములు నుంచి పోవుచుండి",
        "రకలుషవిముగ్ధ లగు కుమారికలు తల్లి ?",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచిరమ్ము",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 16,
      "lines_telugu": [
        "మహితకాసారశుచి కసుమాల మయిన",
        "జీవనం బేమిటికి సరసిజదళాక్షి !",
        "లేచి రా వమ్మ! మాతల్లి! లేచి రమ్ము?",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 17,
      "lines_telugu": [
        "లేచిపోవుట కలవాటు లేని సొగసు",
        "పసపుపిట్టల కీపాప బంధమేల?",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచిరమ్ము!",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 18,
      "lines_telugu": [
        "పరవశాదరు లయిన యావయసు చెలులు",
        "దరిసియుందు రీ సరికి యాత్రాస్థలంబు",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచి రమ్ము !",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 19,
      "lines_telugu": [
        "వెనుక ముందైన కన్యల ననుగు జెలిమి",
        "తోడ రా బిల్చి గెలుపాట లాడవలయు,",
        "లేచి రా వమ్మ ! మాతల్లి ! లేచి రమ్ము!",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 20,
      "lines_telugu": [
        "కందుక క్రీడ కాయత్తకాంక్ష లయిన",
        "పూర్ణనియతలు ఇపుడిప్డె పోయినారు,",
        "లేచి రావమ్మ! మాతల్లి! లేచిరమ్ము!",
        "తెనుగు తోట"
      ],
      "Chandassu": "unknown",
      "chapter": "తెనుగు తోట",
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
      "id": 21,
      "lines_telugu": [
        "దివ్యసమయములను గాని తెఱువరవ్వి;",
        "ద్వారబాంధవి యప్రమాదము వహించె;",
        "లేచిరావమ్మ! మాతల్లి! లేచిరమ్ము!",
        "తెనుగు తోట"
      ],
