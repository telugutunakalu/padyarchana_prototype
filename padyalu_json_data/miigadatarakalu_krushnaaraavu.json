        "వెంటనే కాఁపువానిని విడిచె ఱేఁడు"
      ],
      "Chandassu": "unknown",
      "chapter": null,
      "padyam_number": "unknown",
      "bhavam": null,
      "prathipadartham": null
    },
    {
